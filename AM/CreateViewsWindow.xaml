<Window x:Class="TNovUtilsAR.CreateViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AM_PSO — Создание видов квартир"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TNovCommon;component/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Border CornerRadius="12" Background="White" BorderBrush="#FF008E43" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кастомный заголовок -->
            <Border Grid.Row="0" Height="30" CornerRadius="12 12 0 0"
                    Background="#FF008E43" VerticalAlignment="Top"
                    MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource RoundButtonStyle}"
                            Content="✕" Click="OnCloseClick"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="20" Height="20" Margin="5,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource RoundButtonStyle3}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="20" Height="20" Margin="0"
                            IsHitTestVisible="False"/>
                    <TextBlock Text="Создание видов квартир"
                               Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                </StackPanel>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Источник комнат" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="SourceComboBox" Grid.Row="0" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="DisplayName"/>

                <TextBlock Text="Уровень" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="LevelComboBox" Grid.Row="1" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Номер этажа (для имени)" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <TextBox x:Name="FloorTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6"/>

                <TextBlock Text="Набор АМ" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           FontWeight="Bold" Foreground="#FF008E43" Margin="0,10,0,2"/>

                <TextBlock Text="Шаблон общего вида этажа" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="GeneralTemplateComboBox" Grid.Row="4" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Шаблон ПК (план квартиры)" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="PkTemplateComboBox" Grid.Row="5" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Шаблон ПС, серия (выбрать …-1)" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="PsTemplateComboBox" Grid.Row="6" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Набор ПСО" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                           FontWeight="Bold" Foreground="#FF008E43" Margin="0,10,0,2"/>

                <TextBlock Text="Шаблон общего вида этажа" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="PsoGeneralTemplateComboBox" Grid.Row="8" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Шаблон ПК (план квартиры)" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="PsoPkTemplateComboBox" Grid.Row="9" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Шаблон ПС, серия (выбрать …-1)" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Margin="0,6"/>
                <ComboBox x:Name="PsoPsTemplateComboBox" Grid.Row="10" Grid.Column="1" Margin="0,6"
                          DisplayMemberPath="Name"/>

                <StackPanel Orientation="Horizontal" Grid.Row="11" Grid.Column="1" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Style="{StaticResource CustomButtonStyle}" Content="Отмена"
                            MinWidth="100" MinHeight="26" Margin="0,0,8,0" IsCancel="True"/>
                    <Button Style="{StaticResource CustomButtonStyle}" Content="Создать"
                            MinWidth="100" MinHeight="26" IsDefault="True" Click="OnCreateClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
